    if os.path.exists(ACCOUNTS_FILE):
        with open(ACCOUNTS_FILE, "r") as f:
            accounts = json.load(f)

def save_accounts():
    with open(ACCOUNTS_FILE, "w") as f:
        json.dump(accounts, f, ensure_ascii=False, indent=4)

load_accounts()

def parse_token_json(data: dict) -> dict:
    token = data.get("token", "")
    device_id = data.get("deviceId", str(uuid.uuid4()))
    
    user = data.get("user", {})
    phone = str(user.get("phone", "unknown"))
    if phone != "unknown":
        phone = f"+{phone}"
    
    return {
        "token": token,
        "device_id": device_id,
        "phone": phone
    }

def add_account_from_json(data: dict) -> bool:
    parsed = parse_token_json(data)
    token = parsed["token"]
    
    if not token or len(token) < 20:
        return False
    
    acc_id = str(uuid.uuid4())[:8]
    accounts[acc_id] = {
        "token": token,
        "device_id": parsed["device_id"],
        "phone": parsed["phone"],
        "added_at": time.time(),
        "total_scans": 0
    }
    return True

def process_content(content: str) -> tuple:
    added = 0
    skipped = 0
    
    try:
        data = json.loads(content)
        
        if isinstance(data, list):
            for item in data:
                if isinstance(item, dict):
                    if add_account_from_json(item):
                        added += 1
                    else:
                        skipped += 1
            return added, skipped
        elif isinstance(data, dict):
            if add_account_from_json(data):
                added += 1
            else:
                skipped += 1
            return added, skipped
    except:
        pass
    
    for line in content.strip().split('\n'):
        line = line.strip()
        if not line:
            continue
        
        try:
            data = json.loads(line)
            if isinstance(data, dict):
                if add_account_from_json(data):
                    added += 1
                else:
                    skipped += 1
                continue
        except:
            pass
        
        parts = line.split('|')
        token = parts[0].strip() if len(parts) > 0 else ""
        
        if not token or len(token) < 20:
            skipped += 1
            continue
        
        device_id = parts[1].strip() if len(parts) > 1 else str(uuid.uuid4())
        phone = parts[2].strip() if len(parts) > 2 else "unknown"
        
        acc_id = str(uuid.uuid4())[:8]
        accounts[acc_id] = {
            "token": token,
            "device_id": device_id,
            "phone": phone,
            "added_at": time.time(),
            "total_scans": 0
        }
        added += 1
    
    return added, skipped

