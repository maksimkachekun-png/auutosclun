@dp.callback_query(F.data == "scan_qr")
async def cb_scan_qr(callback: types.CallbackQuery, state: FSMContext):
    if not accounts:
        await callback.answer("❌ Нет доступных аккаунтов", show_alert=True)
        return
    
    await state.set_state(AuthState.waiting_for_qr)
    await callback.message.answer(
        "📷 Отправьте <b>фотографию QR-кода</b>.\n\n"
        "Бот распознает QR и отсканирует его.",
        parse_mode="HTML"
    )
    await callback.answer()

@dp.message(AuthState.waiting_for_qr, F.photo)
async def handle_qr_photo(message: types.Message, state: FSMContext):
    msg = await message.answer("⏳ Распознаю QR-код...")
    
    try:
        photo = message.photo[-1]
        file = await bot.get_file(photo.file_id)
        file_bytes = await bot.download_file(file.file_path)
        
        # Отправляем файл напрямую в Google QR API
        files = {'file': ('qr.png', file_bytes.read())}
        response = requests.post(
            'https://api.qrserver.com/v1/read-qr-code/',
            files=files
        )
        data = response.json()
        
        if data and isinstance(data, list) and len(data) > 0:
            symbol = data[0].get("symbol", [])
            if symbol and len(symbol) > 0:
                qr_data = symbol[0].get("data", "")
                if qr_data:
                    await process_qr(message, state, qr_data, msg)
                    return
        
        await msg.edit_text("❌ QR-код не найден на фото. Попробуйте другое фото.")
        
    except Exception as e:
        await msg.edit_text(f"❌ Ошибка распознавания: {e}")

async def process_qr(message: types.Message, state: FSMContext, qr_input: str, msg):
    qr_link = qr_input
    track_id = None
    
    if "web.max.ru/link/" in qr_input:
        try:
            track_id = qr_input.split("/link/")[1].split("?")[0]
        except:
            pass
    
    if not track_id:
        await msg.edit_text("❌ Не удалось извлечь ID из QR. Отправьте корректный QR-код.")
        return
    
    acc_ids = list(accounts.keys())
    if not acc_ids:
        await msg.edit_text("❌ Нет доступных аккаунтов")
        await state.clear()
        return
    
    acc_id = acc_ids[0]
    acc = accounts[acc_id]
    
    acc_copy = dict(accounts[acc_id])
    del accounts[acc_id]
    accounts[acc_id] = acc_copy
    save_accounts()
    
    await msg.edit_text(f"⏳ Сканирую QR через {acc['phone']}...")
    
    scanner = QRScanner(acc["token"], acc["device_id"])
    
    result = None
    def do_scan():
        nonlocal result
        result = scanner.scan(track_id, qr_link)
    
    threading.Thread(target=do_scan, daemon=True).start()
    
    for _ in range(30):
        if result: break
        await asyncio.sleep(0.5)
    
    if result is None:
        await msg.edit_text("❌ Таймаут сканирования")
    elif result.get("success"):
        accounts[acc_id]["total_scans"] = accounts[acc_id].get("total_scans", 0) + 1
        save_accounts()
        await msg.edit_text(f"✅ QR успешно отсканирован!\nАккаунт: {acc['phone']}")
    else:
        await msg.edit_text(f"❌ Ошибка: {result.get('error', 'неизвестно')}")
    
    await state.clear()

