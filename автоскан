@dp.message(F.document)
async def handle_document(message: types.Message):
    if message.from_user.id != ADMIN_ID:
        return
    
    doc = message.document
    file_name = doc.file_name.lower()
    
    if not file_name.endswith(('.txt', '.json', '.zip')):
        await message.answer("❌ Отправьте файл .txt, .json или .zip")
        return
    
    msg = await message.answer("⏳ Обрабатываю файл...")
    
    try:
        file = await bot.get_file(doc.file_id)
        file_bytes = await bot.download_file(file.file_path)
        
        added = 0
        skipped = 0
        
        if file_name.endswith('.zip'):
            zip_buffer = BytesIO(file_bytes.read())
            with zipfile.ZipFile(zip_buffer, 'r') as zf:
                for inner_file in zf.namelist():
                    if not inner_file.endswith(('.txt', '.json')):
                        continue
                    
                    try:
                        content = zf.read(inner_file).decode('utf-8')
                        a, s = process_content(content)
                        added += a
                        skipped += s
                    except:
                        skipped += 1
        else:
            content = file_bytes.read().decode('utf-8')
            added, skipped = process_content(content)
        
        save_accounts()
        
        await msg.edit_text(
            f"✅ Файл обработан!\n\n"
            f"➕ Добавлено: <b>{added}</b>\n"
            f"⏭ Пропущено: <b>{skipped}</b>\n"
            f"📊 Всего аккаунтов: <b>{len(accounts)}</b>",
            parse_mode="HTML"
        )
        
    except Exception as e:
        await msg.edit_text(f"❌ Ошибка обработки файла: {e}")

